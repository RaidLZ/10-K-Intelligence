# ─────────────────────────────────────────────────────────────
#  10-K Intelligence — configuration
#  Copy to `.env` and edit. Everything has a sensible local default;
#  the only REQUIRED field is SEC_IDENTITY (the SEC blocks anonymous bulk access).
# ─────────────────────────────────────────────────────────────

# REQUIRED: SEC EDGAR fair-access policy wants a contact string "Name email".
SEC_IDENTITY="Anonymous example@example.com"

# ── LLM provider ──────────────────────────────────────────────
# ollama (default, fully local) | openai | anthropic
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b-instruct

# Optional API fallback — fill a key and switch LLM_PROVIDER to use it.
# Recommended for the one slow step on CPU: `make graph` (batch extraction).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Embeddings (FastEmbed, runs on CPU) ───────────────────────
EMBED_MODEL=BAAI/bge-base-en-v1.5
SPARSE_MODEL=Qdrant/bm25
RERANK_MODEL=BAAI/bge-reranker-base

# ── Stores ────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=tenk_chunks
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=tenkpassword

# ── Corpus (v1: small, scales by adding tickers) ──────────────
TICKERS=AAPL,MSFT,NVDA,GOOGL,AMZN,META
YEARS=2022,2023,2024
DATA_DIR=./data

# ── Retrieval knobs ───────────────────────────────────────────
TOP_K=20            # candidates before rerank
FINAL_K=6           # chunks passed to the LLM
RELEVANCE_THRESHOLD=0.45   # Corrective-RAG: below this -> rewrite/fallback
